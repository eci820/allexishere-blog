---
// 화면 맨 아래 푸터. 참고 블로그처럼 간결하게.
import { SITE } from '../consts';
const year = 2026;
---

<footer class="border-t border-[var(--border)] mt-16">
  <div
    class="mx-auto max-w-wide px-5 py-8 flex items-center justify-between text-xs text-[var(--muted)]"
  >
    <div>
      <nav class="flex flex-wrap gap-x-4 gap-y-1">
        <a href="/about" class="hover:text-[var(--fg)] transition">소개</a>
        <a href="/privacy" class="hover:text-[var(--fg)] transition">개인정보처리방침</a>
        <a href="/rss.xml" class="hover:text-[var(--fg)] transition">RSS</a>
      </nav>
      <div class="mt-2">{SITE.title}</div>
      <div class="mt-1">© {year} Allex is here!</div>
    </div>
    <a
      href="#top"
      class="rounded-full border border-[var(--border)] w-9 h-9 flex items-center justify-center transition hover:bg-black/5 dark:hover:bg-white/10"
      aria-label="맨 위로"
      title="맨 위로"
    >
      ↑
    </a>
  </div>
</footer>

---
// 수동 광고 한 칸(현재 본문 끝 슬롯에 사용).
// - 실제 광고(<ins>)는 배포(운영)에서, 슬롯 ID 가 채워졌을 때만 로드.
// - 미충전(data-ad-status=unfilled) 시 global.css 규칙으로 접혀 공백이 안 남음.
// - 충전 시 min-height 로 CLS 예약. 개발 중에는 위치 확인용 얇은 마커.
import { ADSENSE } from '../consts';

interface Props {
  slot?: string;
  minHeight?: number;
  label?: string;
}

const { slot = '', minHeight = 280, label = '광고 자리' } = Astro.props;
const client = ADSENSE.publisherId;
const showReal = import.meta.env.PROD && slot.length > 0;
const showPlaceholder = import.meta.env.DEV;
---

{
  showReal ? (
    <ins
      class="adsbygoogle my-8 block"
      style={`display:block;width:100%;min-height:${minHeight}px`}
      data-ad-client={client}
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"
    />
  ) : showPlaceholder ? (
    <div
      class="my-6 w-full rounded-md border border-dashed border-[var(--border)] py-2 text-center text-xs"
      style="color:var(--muted)"
    >
      {label}
    </div>
  ) : null
}

{showReal && (
  <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
)}

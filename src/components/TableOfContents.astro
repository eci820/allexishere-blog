---
// 목차(TOC). 소제목(h2)이 3개 이상인 글에서만 노출합니다.
// 텍스트 우선 디자인에 맞춘 미니멀 스타일 — 얇은 테두리 박스에 번호 없는 목록.
// headings 는 Astro 의 render() 가 준 { depth, slug, text } 배열입니다.
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
// h2 만 목차로. (h3 이하는 세부 항목이라 목차가 길어지지 않게 제외)
const items = headings.filter((h) => h.depth === 2 && h.slug && h.text);
const show = items.length >= 3;
---

{
  show && (
    <nav
      class="mb-8 rounded-lg border border-[var(--border)] px-5 py-4"
      aria-label="목차"
    >
      <p class="mb-2 text-xs font-semibold tracking-wide text-[var(--muted)]">
        목차
      </p>
      <ul class="space-y-1.5">
        {items.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class="text-sm leading-snug text-[var(--fg)] hover:text-[var(--accent)] hover:underline"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

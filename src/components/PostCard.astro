---
// 글 목록 카드 (텍스트 우선). 구성: 제목(2줄) + 발행일 + 요약(2줄).
// 대표이미지 없는 글이 기본값이므로 썸네일을 쓰지 않아 어떤 조합에서도 안 깨집니다.
import type { CollectionEntry } from 'astro:content';
import { getPostUrl } from '../utils/url';
import { makeExcerpt } from '../utils/excerpt';
import { formatDate } from '../utils/date';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const href = getPostUrl(post);
// 미리보기 텍스트: 요약(description)이 있으면 그것, 없으면 본문 앞부분에서 생성
const excerpt = post.data.description?.trim() || makeExcerpt(post.body ?? '');
const date = formatDate(post.data.pubDate);
---

<article class="group">
  <a href={href} class="block">
    <!-- 제목 (최대 2줄) -->
    <h2
      class="text-base font-bold leading-snug line-clamp-2 transition group-hover:text-[var(--accent)]"
    >
      {post.data.title}
    </h2>

    <!-- 발행일 -->
    <p class="mt-1.5 text-xs text-[var(--muted)]">{date}</p>

    <!-- 요약 (최대 2줄) -->
    <p class="mt-2 text-sm leading-relaxed text-[var(--muted)] line-clamp-2">
      {excerpt}
    </p>
  </a>
</article>

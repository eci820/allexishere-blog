---
// 글 상세 페이지. 주소는 티스토리 원본과 동일한 /entry/제목 형식으로 생성합니다.
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ParkingCalculator from '../../components/ParkingCalculator.astro';
import ParkingCompare from '../../components/ParkingCompare.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { SITE, ADSENSE } from '../../consts';
import { getPostUrl } from '../../utils/url';
import { makeExcerpt } from '../../utils/excerpt';
import { formatDate } from '../../utils/date';
import { getPublishedPosts } from '../../utils/posts';
import { getRelatedPosts } from '../../utils/related';
import { extractFaq, buildFaqJsonLd } from '../../utils/faq';

export const getStaticPaths = (async () => {
  // 초안은 운영 빌드에서만 제외(개발에서는 미리보기 위해 포함)
  const posts = await getCollection('blog', ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true
  );
  return posts
    .map((post) => ({ post, url: getPostUrl(post) }))
    // 이 파일은 /entry/... 주소만 담당합니다.
    .filter(({ url }) => url.startsWith('/entry/'))
    .map(({ post, url }) => ({
      params: { slug: url.replace(/^\/entry\//, '') },
      props: { post },
    }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
// headings: 목차(TOC)용 소제목 목록을 함께 받습니다.
const { Content, headings } = await render(post);

const description =
  post.data.description?.trim() || makeExcerpt(post.body ?? '', 160);
const canonicalURL = new URL(getPostUrl(post), SITE.url).href;
const ogImage = post.data.cover?.src ?? SITE.defaultOgImage;

// '함께 읽으면 좋은 글' — 이관 글 포함 전체 발행글 중 관련도 높은 2~3편.
const allPosts = await getPublishedPosts();
const relatedPosts = getRelatedPosts(post, allPosts, 3);

// 구글 검색용 구조화 데이터(Article)
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Person', name: SITE.author },
  publisher: { '@type': 'Organization', name: SITE.title },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL },
  url: canonicalURL,
};

// 본문에 '자주 묻는 질문' 섹션이 있으면 FAQPage 스키마도 함께 출력.
// (Article 과 FAQPage 를 배열로 넘기면 head 에 하나의 JSON-LD 로 합쳐집니다)
const faqJsonLd = buildFaqJsonLd(extractFaq(post.body ?? ''));
const jsonLd = faqJsonLd ? [articleJsonLd, faqJsonLd] : articleJsonLd;
---

<BaseLayout
  title={post.data.title}
  description={description}
  image={ogImage}
  article={true}
  publishedTime={post.data.pubDate.toISOString()}
  modifiedTime={(post.data.updatedDate ?? post.data.pubDate).toISOString()}
  jsonLd={jsonLd}
>
  <main id="top" class="mx-auto max-w-content px-5 py-10">
    <!-- 글 제목 (날짜는 화면에 표시하지 않음) -->
    <header class="mb-8">
      <h1 class="font-serif text-3xl font-extrabold leading-tight tracking-tight">
        {post.data.title}
      </h1>

      <!-- 날짜: '최종 업데이트' 하나만 표시. 값은 수정일이 있으면 수정일, 없으면 발행일.
           JSON-LD 의 datePublished/dateModified 는 별도로 정확한 값을 유지합니다. -->
      <p class="mt-3 text-sm text-[var(--muted)]">
        {`최종 업데이트: ${formatDate(post.data.updatedDate ?? post.data.pubDate)}`}
      </p>

      {
        post.data.tags.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <li class="rounded-full border border-[var(--border)] px-3 py-1 text-xs text-[var(--muted)]">
                #{tag}
              </li>
            ))}
          </ul>
        )
      }
    </header>

    <!-- 🅿️ 주차요금 계산기(frontmatter parkingCalc 설정 시 제목 아래에 렌더) -->
    {post.data.parkingCalc && <ParkingCalculator facility={post.data.parkingCalc} />}

    <!-- 🅿️ 주차장 요금·거리 비교표(frontmatter parkingCompare 설정 시 제목 아래에 렌더) -->
    {post.data.parkingCompare && <ParkingCompare id={post.data.parkingCompare} />}

    <!-- 대표 이미지(있을 때만) -->
    {
      post.data.cover && (
        <Image
          src={post.data.cover}
          alt={post.data.coverAlt ?? post.data.title}
          widths={[400, 800, 1200]}
          sizes="(max-width: 720px) 100vw, 720px"
          class="mb-8 w-full rounded-lg"
          loading="eager"
        />
      )
    }

    <!-- 목차(TOC): h2 3개 이상인 글에만 자동 노출. 탭하면 해당 섹션으로 이동 -->
    <TableOfContents headings={headings} />

    <!-- 본문. prose 클래스가 제목·목록·이미지 여백을 자동으로 예쁘게 잡습니다.
         이미지를 여러 장 넣어도 각 이미지가 알아서 정리됩니다. -->
    <article
      class="prose prose-neutral dark:prose-invert max-w-none
             prose-img:rounded-lg prose-img:mx-auto
             prose-headings:font-bold prose-a:text-[var(--accent-ink)]"
    >
      <Content />
    </article>

    <!-- 함께 읽으면 좋은 글: 본문 끝, 하단 광고 위 -->
    <RelatedPosts posts={relatedPosts} />

    <!-- [광고 3] 본문 맨 끝 -->
    <AdUnit slot={ADSENSE.slots.bottom} minHeight={280} label="광고 자리 (본문 끝)" />

    <!-- 상단(리드 직후)·중간(첫 소제목 뒤) 광고를 스크립트로 삽입.
         본문이 마크다운 렌더라 위치를 클라이언트에서 잡습니다.
         미충전(data-ad-status=unfilled) 광고는 global.css 에서 접혀 공백이 남지 않습니다. -->
    <div
      id="ad-config"
      data-top-slot={ADSENSE.slots.top}
      data-mid-slot={ADSENSE.slots.inArticle}
      data-client={ADSENSE.publisherId}
      data-prod={String(import.meta.env.PROD)}
      hidden
    >
    </div>
    <script is:inline>
      (function () {
        var cfg = document.getElementById('ad-config');
        if (!cfg) return;
        var article = document.querySelector('article.prose');
        if (!article) return;
        var client = cfg.getAttribute('data-client') || '';
        var isProd = cfg.getAttribute('data-prod') === 'true';
        var loaded = [];

        // anchor 바로 뒤에 광고 삽입. 운영=<ins>(미충전 시 CSS로 접힘), 개발=위치 마커.
        function insertAd(anchor, slot, opts, devLabel) {
          if (isProd && !slot) return; // 운영인데 슬롯 비면 삽입 안 함
          var el;
          if (isProd && slot) {
            el = document.createElement('ins');
            el.className = 'adsbygoogle my-8';
            el.style.display = 'block';
            el.style.width = '100%';
            el.style.minHeight = opts.minHeight + 'px'; // 충전 시 CLS 예약(미충전은 접힘)
            el.setAttribute('data-ad-client', client);
            el.setAttribute('data-ad-slot', slot);
            el.setAttribute('data-ad-format', opts.format);
            if (opts.layout) el.setAttribute('data-ad-layout', opts.layout);
            else el.setAttribute('data-full-width-responsive', 'true');
          } else {
            // 개발: 위치만 확인하는 얇은 마커(공백 최소)
            el = document.createElement('div');
            el.className =
              'my-6 w-full rounded-md border border-dashed border-[var(--border)] text-center text-xs py-2';
            el.style.color = 'var(--muted)';
            el.textContent = devLabel;
          }
          if (anchor) anchor.insertAdjacentElement('afterend', el);
          else article.appendChild(el);
          if (isProd && slot) loaded.push(el);
        }

        // 상단: 첫 문단(리드) 직후 — 첫 소제목(h2)보다 앞이라 중간 슬롯과 겹치지 않음
        insertAd(
          article.querySelector('p'),
          cfg.getAttribute('data-top-slot') || '',
          { minHeight: 100, format: 'auto' },
          '광고 (리드 직후)'
        );
        // 중간: 첫 소제목(h2) 직후
        insertAd(
          article.querySelector('h2'),
          cfg.getAttribute('data-mid-slot') || '',
          { minHeight: 280, format: 'fluid', layout: 'in-article' },
          '광고 (첫 소제목 뒤)'
        );

        for (var i = 0; i < loaded.length; i++) {
          (window.adsbygoogle = window.adsbygoogle || []).push({});
        }
      })();
    </script>

    <!-- 목록으로 돌아가기 -->
    <div class="mt-12 border-t border-[var(--border)] pt-6">
      <a href="/" class="text-sm text-[var(--accent-ink)] hover:underline">
        ← 목록으로
      </a>
    </div>
  </main>
</BaseLayout>

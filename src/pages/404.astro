---
// 404 (없는 주소) 페이지.
// 리다이렉트 대상이 아닌 404 방문자를 붙잡기 위해 최근 글 8개 링크 + 사이트 내 검색을 제공합니다.
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../utils/posts';
import { getPostUrl } from '../utils/url';

const recent = (await getPublishedPosts()).slice(0, 8);
---

<BaseLayout title="페이지를 찾을 수 없습니다" description="요청하신 페이지가 존재하지 않습니다.">
  <main id="top" class="mx-auto max-w-content px-5 py-20">
    <div class="text-center">
      <p class="font-serif text-6xl font-extrabold text-[var(--accent)]">404</p>
      <h1 class="mt-4 text-xl font-bold">페이지를 찾을 수 없습니다</h1>
      <p class="mt-3 text-sm text-[var(--muted)]">
        주소가 바뀌었거나 삭제된 글일 수 있습니다. 아래에서 원하는 글을 찾아보세요.
      </p>
    </div>

    <!-- 사이트 내 검색 (내부 검색엔진이 없어 Google site: 검색으로 연결) -->
    <form
      id="site-search"
      action="https://www.google.com/search"
      method="get"
      role="search"
      class="mx-auto mt-8 flex max-w-md gap-2"
    >
      <input
        type="search"
        name="q"
        required
        placeholder="사이트 내 검색 (예: 재산세, 건강검진)"
        aria-label="사이트 내 검색"
        class="min-w-0 flex-1 rounded-full border border-[var(--border)] bg-transparent px-4 py-2 text-sm outline-none focus:border-[var(--accent)]"
      />
      <button
        type="submit"
        class="shrink-0 rounded-full bg-[var(--accent)] px-5 py-2 text-sm font-medium text-white transition hover:opacity-90"
      >
        검색
      </button>
    </form>

    <!-- 최근 글 8개 -->
    <section class="mx-auto mt-12 max-w-2xl">
      <h2 class="mb-4 text-sm font-semibold text-[var(--muted)]">최근 글</h2>
      <ul class="divide-y divide-[var(--border)]">
        {
          recent.map((post) => (
            <li>
              <a
                href={getPostUrl(post)}
                class="block py-3 text-sm transition hover:text-[var(--accent)]"
              >
                {post.data.title}
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <div class="mt-12 text-center">
      <a
        href="/"
        class="inline-block rounded-full border border-[var(--border)] px-5 py-2 text-sm transition hover:bg-black/5 dark:hover:bg-white/10"
      >
        홈으로 돌아가기
      </a>
    </div>
  </main>

  <script is:inline>
    // JS 가 있으면 'site:allexishere.com' 접두어를 붙여 사이트 내부로 검색을 좁힙니다.
    // (JS 가 없으면 form 이 그대로 Google 일반 검색으로 폴백)
    (function () {
      var f = document.getElementById('site-search');
      if (!f) return;
      f.addEventListener('submit', function (e) {
        var input = f.querySelector('input[type=search]');
        var q = (input && input.value ? input.value : '').trim();
        if (!q) return;
        e.preventDefault();
        window.location.href =
          'https://www.google.com/search?q=' +
          encodeURIComponent('site:allexishere.com ' + q);
      });
    })();
  </script>
</BaseLayout>

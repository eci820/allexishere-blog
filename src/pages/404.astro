---
// 404 (없는 주소) 페이지
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="페이지를 찾을 수 없습니다" description="요청하신 페이지가 존재하지 않습니다.">
  <main
    id="top"
    class="mx-auto max-w-content px-5 py-24 text-center"
  >
    <p class="font-serif text-6xl font-extrabold text-[var(--accent)]">404</p>
    <h1 class="mt-4 text-xl font-bold">페이지를 찾을 수 없습니다</h1>
    <p class="mt-3 text-sm text-[var(--muted)]">
      주소가 바뀌었거나 삭제된 글일 수 있습니다.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-full border border-[var(--border)] px-5 py-2 text-sm transition hover:bg-black/5 dark:hover:bg-white/10"
    >
      홈으로 돌아가기
    </a>
  </main>
</BaseLayout>

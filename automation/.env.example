# 이 파일을 automation/.env 로 복사해서 값을 채우세요. (.env 는 git 에 안 올라갑니다)
#
# 1) 텔레그램 봇 토큰 — BotFather에서 '새로' 만든 봇 (매매봇과 반드시 별개)
TELEGRAM_BOT_TOKEN=

# 2) 내 텔레그램 chat id — 아래로 확인:
#    node automation/getchatid.mjs  실행 후, 그 봇에게 아무 메시지나 보내면 숫자가 찍힙니다.
TELEGRAM_CHAT_ID=

# 3) Anthropic API 키 — 폴백용(구독 헤드리스가 기본이라 선택). console.anthropic.com
ANTHROPIC_API_KEY=

# 4) 네이버 검색광고 API — 월간검색수 (searchad.naver.com > 도구 > API 사용관리)
NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=

# 5) 네이버 오픈API — 블로그 문서수 (developers.naver.com, 검색 API)
NAVER_OPENAPI_CLIENT_ID=
NAVER_OPENAPI_CLIENT_SECRET=

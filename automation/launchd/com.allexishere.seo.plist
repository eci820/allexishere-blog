<plist version="1.0"><dict>
  <key>Label</key><string>com.allexishere.seo</string>
  <key>ProgramArguments</key><array><string>/opt/homebrew/bin/node</string><string>/Users/jeonghunoh/Projects/allexishere-blog/automation/seo-watch.mjs</string></array>
  <key>WorkingDirectory</key><string>/Users/jeonghunoh/Projects/allexishere-blog</string>
